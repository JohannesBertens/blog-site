---
// TerminalWindow.astro — Shared terminal window component for error pages
// Provides consistent terminal styling with configurable accent color

interface Props {
  title?: string;
  accentColor?: 'green' | 'red';
}

const { title = 'user@blog:~', accentColor = 'green' } = Astro.props;
const accentClass = accentColor === 'red' ? 'accent-red' : 'accent-green';
---

<div class="terminal-window">
  <div class="terminal-header">
    <span class="terminal-dot red"></span>
    <span class="terminal-dot yellow"></span>
    <span class="terminal-dot green"></span>
    <span class="terminal-title">{title}</span>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal-window {
    max-width: 680px;
    margin: 4rem auto;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    font-family: var(--font-mono);
    background: var(--bg-secondary);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-primary);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot.red {
    background: #ff5f57;
  }

  .terminal-dot.yellow {
    background: #febc2e;
  }

  .terminal-dot.green {
    background: #28c840;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .terminal-body {
    padding: 24px;
    min-height: 300px;
    background: var(--bg-secondary);
  }

  .terminal-prompt {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  :global(.prompt-symbol) {
    color: var(--accent-green);
    font-weight: bold;
  }

  :global(.prompt-symbol.accent-red) {
    color: var(--accent-red);
  }

  :global(.command) {
    color: var(--text-primary);
  }

  :global(.error-output) {
    margin: 24px 0;
    padding: 16px;
    border-left: 3px solid var(--accent-red);
    background: rgba(248, 81, 73, 0.05);
  }

  :global(.error-title) {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent-red);
    margin-bottom: 8px;
  }

  :global(.error-detail) {
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  :global(.error-hint) {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  :global(.home-link) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-green);
    text-decoration: none;
    margin-top: 16px;
    padding: 8px 12px;
    border-radius: 4px;
    transition: background 0.15s;
  }

  :global(.home-link.accent-red) {
    color: var(--accent-red);
  }

  :global(.home-link:hover) {
    background: var(--bg-tertiary);
  }

  :global(.return-label) {
    color: var(--text-muted);
    margin-left: 8px;
  }

  :global(.cursor-blink) {
    display: inline-block;
    width: 8px;
    height: 1.1em;
    background: var(--accent-green);
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
  }

  :global(.cursor-blink.accent-red) {
    background: var(--accent-red);
  }

  :global(.stack-trace) {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 480px) {
    .terminal-window {
      margin: 2rem 1rem;
    }
    .terminal-body {
      padding: 16px;
    }
    :global(.error-title) {
      font-size: 1.2rem;
    }
  }
</style>
