---
export const prerender = true;

import Layout from './Layout.astro';
import Metadata from '../components/Metadata.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { siteConfig } from '../lib/config';
import { getAllPosts } from '../lib/posts';
import type { BlogPostFrontmatter } from '../lib/types';

interface Props {
  frontmatter: BlogPostFrontmatter;
}

const { frontmatter } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  author = siteConfig.author,
  tags = [],
  readingTime,
  wordCount,
} = frontmatter;

const publishDate = pubDate
  ? typeof pubDate === 'string' ? new Date(pubDate) : pubDate
  : new Date();
const lastUpdated = updatedDate
  ? typeof updatedDate === 'string' ? new Date(updatedDate) : updatedDate
  : undefined;

const safePublishDate = isNaN(publishDate.getTime()) ? new Date() : publishDate;
const safeLastUpdated = lastUpdated && !isNaN(lastUpdated.getTime()) ? lastUpdated : undefined;

const allPosts = getAllPosts();
const currentPostUrl = Astro.url.pathname;
---

<Layout title={title} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <Metadata
        title={title}
        description={description}
        publishDate={safePublishDate}
        updatedDate={safeLastUpdated}
        author={author}
        tags={tags}
        readingTime={readingTime}
        wordCount={wordCount}
      />
    </header>

    <div class="post-layout">
      <TableOfContents />

      <main class="post-content">
        <div class="content-wrapper">
          <slot />
        </div>
        <ShareButtons title={title} url={currentPostUrl} />
      </main>
    </div>

    <RelatedPosts
      currentPostUrl={currentPostUrl}
      currentTags={tags}
      allPosts={allPosts.map((post) => ({
        title: post.frontmatter.title,
        url: post.url,
        description: post.frontmatter.description,
        tags: post.frontmatter.tags || [],
        pubDate: new Date(post.frontmatter.pubDate),
      }))}
    />
  </article>
</Layout>

<style>
  .blog-post {
    min-height: 80vh;
    background: var(--bg-primary);
  }

  .post-layout {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: var(--space-8);
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .post-content {
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    border-radius: 0.75rem;
    padding: var(--space-8);
  }

  @media (max-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .post-sidebar {
      display: none;
    }
    .content-wrapper {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .post-layout {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0;
      margin: 0;
    }
    .post-content {
      padding: var(--space-4);
      margin: 0;
      max-width: 100vw;
    }
    .share-buttons {
      flex-direction: column;
      align-items: center;
    }
    .share-btn {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
