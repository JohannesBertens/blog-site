---
// Main Layout Component
// Provides consistent structure and styling for all pages
import Navigation from '../components/Navigation.astro';
import SEOMeta from '../components/SEOMeta.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../lib/config';
import '../styles/main.css';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description, currentPage = '' } = Astro.props;
---

<!doctype html>
<html lang="en" class="text-optimized">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- SEO Meta Tags -->
    <SEOMeta title={title} description={description} />
    <!-- Optimized Font Loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Skip link for accessibility -->
  </head><a href="#main-content" class="skip-link">Skip to main content</a>


  <body class="performance-optimize">
    <!-- Terminal-style Navigation -->
    <Navigation currentPage={currentPage} />

    <!-- Main Content Area -->
    <main id="main-content" class="main-content" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Scripts for enhanced functionality -->
    <script>
      // Add smooth scroll behavior for anchor links
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const href = anchor.getAttribute('href');
          if (href) {
            const target = document.querySelector(href);
            if (target) {
              target.scrollIntoView({
                behavior: 'smooth',
                block: 'start',
              });
            }
          }
        });
      });

      // Performance monitoring in development
      if (import.meta.env.DEV) {
        window.addEventListener('load', () => {
          const loadTime = performance.now();
          console.log(`Page loaded in ${loadTime.toFixed(2)}ms`);
        });
      }
    </script>
  </body>
</html>
