---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import TagFilter from '../components/TagFilter.astro';
import PostGrid from '../components/PostGrid.astro';
import { getAllPosts, getAllTags, getTagCounts, getFilteredPosts, isValidTag } from '../lib/posts';

// Data loading — single source of truth
const allPosts = getAllPosts();
const allTags = getAllTags();
const tagCounts = getTagCounts();

// Tag filtering logic
const rawTag = Astro.url.searchParams.get('tag');
const { posts: filteredPosts, canonicalTag: currentTag } = getFilteredPosts(rawTag);
const valid = isValidTag(rawTag, tagCounts);
---

<Layout title="Blog - Johannes Developer" currentPage="blog">
  <main class="blog-main">
    <section class="blog-content">
      <div class="container">
        <div class="blog-layout">
          <TagFilter
            allTags={allTags}
            tagCounts={tagCounts}
            currentTag={currentTag}
            totalPosts={allPosts.length}
          />
          <PostGrid
            posts={filteredPosts}
            currentTag={currentTag}
            isValidTag={valid}
          />
        </div>
      </div>
    </section>
  </main>

  <script>
    import { initTagFilter } from '../lib/tagFilter';
    initTagFilter({ updateTitle: true });
  </script>
</Layout>

<style>
  .blog-main {
    min-height: 80vh;
    background: var(--bg-primary);
  }

  .blog-content {
    padding: var(--section-gap) 0;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  /* Responsive design */
  @media (max-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .blog-sidebar {
      position: static;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--space-4);
    }

    .sidebar-section {
      margin-bottom: 0;
    }
  }

  @media (max-width: 768px) {
    .posts-header {
      flex-direction: column;
      gap: var(--space-3);
      align-items: flex-start;
    }
  }
</style>
