---
import Layout from '../layouts/Layout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
---

<Layout title="404 - Command Not Found" description="Page not found">
  <TerminalWindow title="user@blog:~" accentColor="green">
    <div class="terminal-prompt">
      <span class="prompt-symbol">$</span>
      <span class="command">cd /nonexistent/path</span>
    </div>
    <div class="error-output">
      <p class="error-title">zsh: command not found: /nonexistent/path</p>
      <p class="error-detail">Error 404: Page not found</p>
      <p class="error-hint">The page you're looking for doesn't exist or has been moved.</p>
    </div>
    <div class="terminal-prompt">
      <span class="prompt-symbol">$</span>
      <span class="cursor-blink"></span>
    </div>
    <nav aria-label="Navigation">
      <a href="/" class="home-link">
        <span class="prompt-symbol">$</span>
        <span class="command">cd /</span>
        <span class="return-label"> → Go Home</span>
      </a>
    </nav>
  </TerminalWindow>
</Layout>